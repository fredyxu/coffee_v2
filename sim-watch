#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
SIM_DIR="${ROOT_DIR}/simulator"
BUILD_DIR="${SIM_DIR}/build"
BIN="${BUILD_DIR}/coffee_sim"

SIM_PID=""

WATCH_TARGETS=(
  "${ROOT_DIR}/simulator/src"
  "${ROOT_DIR}/simulator/include"
  "${ROOT_DIR}/simulator/CMakeLists.txt"
  "${ROOT_DIR}/simulator/lv_conf.h"
  "${ROOT_DIR}/main/modules/ui"
  "${ROOT_DIR}/main/config"
)

cleanup() {
  if [[ -n "${SIM_PID}" ]] && kill -0 "${SIM_PID}" >/dev/null 2>&1; then
    kill "${SIM_PID}" >/dev/null 2>&1 || true
    wait "${SIM_PID}" 2>/dev/null || true
  fi
}

build_and_run() {
  echo "[sim-watch] building..."
  cmake -S "${SIM_DIR}" -B "${BUILD_DIR}"
  cmake --build "${BUILD_DIR}" -j 8

  if [[ -n "${SIM_PID}" ]] && kill -0 "${SIM_PID}" >/dev/null 2>&1; then
    echo "[sim-watch] restarting simulator..."
    kill "${SIM_PID}" >/dev/null 2>&1 || true
    wait "${SIM_PID}" 2>/dev/null || true
  fi

  "${BIN}" &
  SIM_PID=$!
  echo "[sim-watch] simulator running, pid=${SIM_PID}"
}

snapshot() {
  local files=()
  local p
  for p in "${WATCH_TARGETS[@]}"; do
    if [[ -d "${p}" ]]; then
      while IFS= read -r f; do
        files+=("${f}")
      done < <(find "${p}" -type f \
        \( -name "*.c" -o -name "*.h" -o -name "CMakeLists.txt" -o -name "lv_conf.h" \))
    elif [[ -f "${p}" ]]; then
      files+=("${p}")
    fi
  done

  if [[ "${#files[@]}" -eq 0 ]]; then
    echo "empty"
    return 0
  fi

  printf '%s\n' "${files[@]}" | sort | while IFS= read -r f; do
    stat -f "%m %z %N" "${f}"
  done | shasum | awk '{print $1}'
}

trap cleanup EXIT INT TERM

build_and_run
last_sig="$(snapshot)"

echo "[sim-watch] watching for file changes..."

while true; do
  sleep 1
  current_sig="$(snapshot)"
  if [[ "${current_sig}" != "${last_sig}" ]]; then
    last_sig="${current_sig}"
    build_and_run
  fi
done

