#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_DIR="$ROOT_DIR/build"
RELEASE_DIR="$ROOT_DIR/release"
LATEST_DIR="$RELEASE_DIR/latest"
VERSION_FILE="$ROOT_DIR/VERSION"
VERSION_HEADER="$ROOT_DIR/main/app/app_version.h"
IDF_EXPORT="${IDF_EXPORT:-/Users/Fredy/esp/v5.5.4/esp-idf/export.sh}"
PROJECT_NAME="${PROJECT_NAME:-coffee}"

usage() {
  cat <<'EOF'
Usage:
  ./fw                Build firmware and export binaries to release/latest
  ./fw export         Export binaries only (requires existing build outputs)
  ./fw build          Build only
  ./fw release [tag]  Build and export to release/<tag>, then update release/latest
  ./fw help           Show this help

Environment overrides:
  IDF_EXPORT          ESP-IDF export.sh path (default: /Users/Fredy/esp/v5.5.4/esp-idf/export.sh)
  PROJECT_NAME        App binary base name (default: coffee)
  ALLOW_DIRTY_RELEASE Set to 1 to allow ./fw release from a dirty worktree
EOF
}

read_version() {
  if [[ ! -f "$VERSION_FILE" ]]; then
    echo "VERSION file not found: $VERSION_FILE" >&2
    exit 1
  fi

  local version
  version="$(tr -d '[:space:]' < "$VERSION_FILE")"
  if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "Invalid VERSION: $version" >&2
    echo "Expected format: MAJOR.MINOR.PATCH, for example 0.1.0" >&2
    exit 1
  fi

  echo "$version"
}

git_commit() {
  git -C "$ROOT_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown"
}

git_is_dirty() {
  if ! git -C "$ROOT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo 0
    return
  fi

  if git -C "$ROOT_DIR" diff --quiet --ignore-submodules -- &&
     git -C "$ROOT_DIR" diff --cached --quiet --ignore-submodules --; then
    echo 0
  else
    echo 1
  fi
}

git_describe_version() {
  git -C "$ROOT_DIR" describe --tags --dirty --always 2>/dev/null || true
}

firmware_version_string() {
  local version="$1"
  local commit="$2"
  local dirty="$3"
  local described
  described="$(git_describe_version)"

  if [[ "$described" == v* ]]; then
    echo "$described"
    return
  fi

  local fw="v${version}-g${commit}"
  if [[ "$dirty" == "1" ]]; then
    fw="${fw}-dirty"
  fi
  echo "$fw"
}

generate_version_header() {
  local version commit dirty tag fw_version
  version="$(read_version)"
  commit="$(git_commit)"
  dirty="$(git_is_dirty)"
  tag="v${version}"
  fw_version="$(firmware_version_string "$version" "$commit" "$dirty")"

  cat > "$VERSION_HEADER" <<EOF
#pragma once

/* Generated by ./fw. Keep VERSION as the source version number. */
#define APP_VERSION "${version}"
#define APP_GIT_TAG "${tag}"
#define APP_GIT_COMMIT "${commit}"
#define APP_GIT_DIRTY ${dirty}
#define APP_FIRMWARE_VERSION "${fw_version}"
EOF

  echo "Version header updated: ${fw_version}"
}

build_project() {
  if [[ ! -f "$IDF_EXPORT" ]]; then
    echo "IDF export script not found: $IDF_EXPORT" >&2
    exit 1
  fi
  generate_version_header
  /bin/zsh -lc "source \"$IDF_EXPORT\" >/tmp/esp_export.log && cd \"$ROOT_DIR\" && idf.py build"
}

export_firmware() {
  local out_dir="${1:-$LATEST_DIR}"
  local version_label="${2:-latest}"
  local app_bin="$BUILD_DIR/${PROJECT_NAME}.bin"
  local boot_bin="$BUILD_DIR/bootloader/bootloader.bin"
  local part_bin="$BUILD_DIR/partition_table/partition-table.bin"
  local version commit dirty fw_version build_time

  for f in "$app_bin" "$boot_bin" "$part_bin"; do
    if [[ ! -f "$f" ]]; then
      echo "Missing build artifact: $f" >&2
      echo "Run ./fw (or ./fw build) first." >&2
      exit 1
    fi
  done

  version="$(read_version)"
  commit="$(git_commit)"
  dirty="$(git_is_dirty)"
  fw_version="$(firmware_version_string "$version" "$commit" "$dirty")"
  build_time="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  mkdir -p "$out_dir"

  cp "$app_bin" "$out_dir/"
  cp "$boot_bin" "$out_dir/"
  cp "$part_bin" "$out_dir/"

  cat > "$out_dir/flash_args" <<EOF
--flash_mode dio --flash_freq 80m --flash_size 16MB
0x0 bootloader.bin
0x10000 ${PROJECT_NAME}.bin
0x8000 partition-table.bin
EOF

  cat > "$out_dir/flasher_args.json" <<EOF
{
    "write_flash_args" : [ "--flash_mode", "dio",
                           "--flash_size", "16MB",
                           "--flash_freq", "80m" ],
    "flash_settings" : {
        "flash_mode": "dio",
        "flash_size": "16MB",
        "flash_freq": "80m"
    },
    "flash_files" : {
        "0x0" : "bootloader.bin",
        "0x10000" : "${PROJECT_NAME}.bin",
        "0x8000" : "partition-table.bin"
    },
    "bootloader" : { "offset" : "0x0", "file" : "bootloader.bin", "encrypted" : "false" },
    "app" : { "offset" : "0x10000", "file" : "${PROJECT_NAME}.bin", "encrypted" : "false" },
    "partition-table" : { "offset" : "0x8000", "file" : "partition-table.bin", "encrypted" : "false" },
    "extra_esptool_args" : {
        "after"  : "hard_reset",
        "before" : "default_reset",
        "stub"   : true,
        "chip"   : "esp32s3"
    }
}
EOF

  cat > "$out_dir/README.txt" <<EOF
ZClub Coffee Firmware

Version: ${version_label}
Firmware Version: ${fw_version}
Commit: ${commit}
Dirty Worktree: ${dirty}
Build Time UTC: ${build_time}
Target: ESP32-S3

Files:
- ${PROJECT_NAME}.bin
- bootloader.bin
- partition-table.bin
- flash_args (if generated)
- flasher_args.json (if generated)

Flash command example:
  idf.py -p <PORT> flash

Or from this folder with esptool (if flash_args exists):
  python -m esptool --chip esp32s3 -b 460800 --before default_reset --after hard_reset write_flash @flash_args
EOF

  echo "Export complete: $out_dir"
}

ensure_release_allowed() {
  local tag="$1"
  local version
  version="$(read_version)"

  if [[ ! "$tag" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "Invalid release tag: $tag" >&2
    echo "Expected format: vMAJOR.MINOR.PATCH, for example v0.1.0" >&2
    exit 1
  fi

  if [[ "$tag" != "v${version}" ]]; then
    echo "Release tag $tag does not match VERSION $version" >&2
    exit 1
  fi

  if [[ "$(git_is_dirty)" == "1" && "${ALLOW_DIRTY_RELEASE:-0}" != "1" ]]; then
    echo "Refusing release from dirty worktree." >&2
    echo "Commit or stash changes first, or set ALLOW_DIRTY_RELEASE=1." >&2
    exit 1
  fi
}

release_firmware() {
  local tag="${1:-v$(read_version)}"
  ensure_release_allowed "$tag"
  build_project
  export_firmware "$RELEASE_DIR/$tag" "$tag"
  export_firmware "$LATEST_DIR" "$tag"
}

cmd="${1:-all}"
case "$cmd" in
  all)
    build_project
    export_firmware
    ;;
  build)
    build_project
    ;;
  export)
    export_firmware
    ;;
  release)
    release_firmware "${2:-}"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
