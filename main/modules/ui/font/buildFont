#!/bin/bash

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
FONT_SRC="$ROOT/font/font.otf"
CHARS_FILE="$ROOT/font/chars.txt"
OUT_DIR="$ROOT/font"
SVG_DIR="$ROOT/font/svg"
ICON_MAP_FILE="$ROOT/font/icon_map.txt"
ICON_HEADER="$ROOT/theme/font_icons.h"
ICON_SYMBOLS_FILE="$ROOT/font/icon_symbols.txt"
ALL_SYMBOLS_FILE="$ROOT/font/all_symbols.txt"
ICON_TTF="$ROOT/font/icon_font.ttf"
MERGED_TTF="$ROOT/font/font_merged.ttf"

if [ ! -f "$FONT_SRC" ]; then
  echo "font file not found: $FONT_SRC" >&2
  exit 1
fi

if [ ! -f "$CHARS_FILE" ]; then
  echo "chars file not found: $CHARS_FILE" >&2
  exit 1
fi

if [ $# -eq 0 ]; then
  TAGS=(12 14 16)
else
  TAGS=("$@")
fi

mkdir -p "$SVG_DIR"

python - "$SVG_DIR" "$ICON_MAP_FILE" "$ICON_HEADER" "$ICON_SYMBOLS_FILE" <<'PY'
from pathlib import Path
import re
import sys

svg_dir = Path(sys.argv[1])
map_file = Path(sys.argv[2])
header_file = Path(sys.argv[3])
symbols_file = Path(sys.argv[4])

svg_files = sorted(svg_dir.glob("*.svg"))

existing = {}
if map_file.exists():
    for line in map_file.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        value = value.strip()
        if key and value.startswith("0x"):
            existing[key] = int(value, 16)

def normalize_name(stem: str) -> str:
    name = re.sub(r"[^a-zA-Z0-9]+", "_", stem.strip())
    name = re.sub(r"_+", "_", name).strip("_")
    if not name:
        name = "ICON"
    if name[0].isdigit():
        name = f"ICON_{name}"
    return name.upper()

used_codes = set(existing.values())
next_code = 0xE000

def alloc_code() -> int:
    global next_code
    while next_code in used_codes:
        next_code += 1
    code = next_code
    used_codes.add(code)
    next_code += 1
    return code

mapping = {}
for svg in svg_files:
    key = normalize_name(svg.stem)
    if key in existing:
        mapping[key] = existing[key]
    else:
        mapping[key] = alloc_code()

map_lines = ["# Auto-generated by buildFont", "# NAME=0xCODEPOINT"]
for key in sorted(mapping.keys()):
    map_lines.append(f"{key}=0x{mapping[key]:04X}")
map_file.write_text("\n".join(map_lines) + "\n", encoding="utf-8")

header_lines = [
    "#pragma once",
    "",
    "/* Auto-generated by main/modules/ui/font/buildFont */",
]
for key in sorted(mapping.keys()):
    header_lines.append(f'#define {key} "\\u{mapping[key]:04X}"')
if not mapping:
    header_lines.append("/* no svg icons found in main/modules/ui/font/svg */")
header_lines.append("")
header_file.parent.mkdir(parents=True, exist_ok=True)
header_file.write_text("\n".join(header_lines), encoding="utf-8")

symbols = "".join(chr(mapping[k]) for k in sorted(mapping.keys()))
symbols_file.write_text(symbols, encoding="utf-8")
PY

if [ $? -ne 0 ]; then
  echo "failed generating icon map/header from svg icons" >&2
  exit 1
fi

if ls "$SVG_DIR"/*.svg >/dev/null 2>&1; then
  if ! command -v fontforge >/dev/null 2>&1; then
    echo "fontforge is required to convert svg icons to ttf. install it first." >&2
    echo "macOS: brew install fontforge" >&2
    exit 1
  fi

  fontforge -lang=py -script - "$SVG_DIR" "$ICON_MAP_FILE" "$ICON_TTF" <<'PY'
import fontforge
from pathlib import Path
import re
import sys

svg_dir = Path(sys.argv[1])
map_file = Path(sys.argv[2])
icon_ttf = Path(sys.argv[3])

mapping = {}
for line in map_file.read_text(encoding="utf-8").splitlines():
    line = line.strip()
    if not line or line.startswith("#") or "=" not in line:
        continue
    k, v = line.split("=", 1)
    mapping[k.strip()] = int(v.strip(), 16)

def normalize_name(stem: str) -> str:
    name = re.sub(r"[^a-zA-Z0-9]+", "_", stem.strip())
    name = re.sub(r"_+", "_", name).strip("_")
    if not name:
        name = "ICON"
    if name[0].isdigit():
        name = f"ICON_{name}"
    return name.upper()

font = fontforge.font()
font.encoding = "UnicodeFull"
font.em = 1024
font.ascent = 896
font.descent = 128

for svg in sorted(svg_dir.glob("*.svg")):
    key = normalize_name(svg.stem)
    if key not in mapping:
        continue
    code = mapping[key]
    glyph = font.createChar(code, key)
    glyph.importOutlines(str(svg))
    glyph.simplify()
    glyph.removeOverlap()
    glyph.round()
    glyph.autoHint()
    if glyph.width <= 0:
        glyph.width = 1024

font.generate(str(icon_ttf))
PY
  if [ $? -ne 0 ]; then
    echo "svg to ttf failed" >&2
    exit 1
  fi

  fontforge -lang=py -script - "$FONT_SRC" "$ICON_TTF" "$MERGED_TTF" <<'PY'
import fontforge
import sys

base_font = fontforge.open(sys.argv[1])
base_font.mergeFonts(sys.argv[2])
base_font.generate(sys.argv[3])
PY
  if [ $? -ne 0 ]; then
    echo "merge icon font to base font failed" >&2
    exit 1
  fi
  FONT_TO_BUILD="$MERGED_TTF"
else
  : > "$ICON_SYMBOLS_FILE"
  FONT_TO_BUILD="$FONT_SRC"
fi

cat "$CHARS_FILE" "$ICON_SYMBOLS_FILE" | tr -d '\n' > "$ALL_SYMBOLS_FILE"
SYMBOLS=$(cat "$ALL_SYMBOLS_FILE")

cleanup_font() {
  local path="$1"
  python - <<PY
from pathlib import Path

p = Path("$path")
text = p.read_text()
text = text.replace('#include "lvgl/lvgl.h"', '#include "lvgl.h"')
header_start = text.find("/*******************************************************************************")
if header_start != -1:
    header_end = text.find("******************************************************************************/", header_start)
    if header_end != -1:
        header_end += len("******************************************************************************/")
        text = text[header_end:].lstrip("\n")
p.write_text(text)
PY
}

for SIZE in "${TAGS[@]}"; do
  OUT="$OUT_DIR/font_${SIZE}.c"
  echo "building font size $SIZE -> $OUT"
  lv_font_conv \
    --font "$FONT_TO_BUILD" \
    --size "$SIZE" \
    --bpp 4 \
    --format lvgl \
    --symbols "$SYMBOLS" \
    --range 0x20-0x7F \
    --no-compress \
    --output "$OUT"
  if [ $? -ne 0 ]; then
    echo "lv_font_conv failed for size $SIZE" >&2
    exit 1
  fi
  cleanup_font "$OUT"
done

echo "font build complete"
