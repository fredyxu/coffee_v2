#!/bin/bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
FONT_SRC="$ROOT/font/font.otf"
CHARS_FILE="$ROOT/font/chars.txt"
OUT_DIR="$ROOT/font"
ICONFONT_DIR="$ROOT/font/iconfont"
ICON_MAP_FILE="$ROOT/font/icon_map.txt"
ICON_HEADER="$ROOT/theme/font_icons.h"
ICON_SYMBOLS_FILE="$ROOT/font/icon_symbols.txt"
ALL_SYMBOLS_FILE="$ROOT/font/all_symbols.txt"
ICON_ENTRIES_FILE="$ROOT/font/icon_font_entries.txt"

if [ ! -f "$FONT_SRC" ]; then
  echo "font file not found: $FONT_SRC" >&2
  exit 1
fi

if [ ! -f "$CHARS_FILE" ]; then
  echo "chars file not found: $CHARS_FILE" >&2
  exit 1
fi

if [ $# -eq 0 ]; then
  TAGS=(12 14 16)
else
  TAGS=("$@")
fi

mkdir -p "$ICONFONT_DIR"

python3 - "$ICONFONT_DIR" "$ICON_MAP_FILE" "$ICON_HEADER" "$ICON_SYMBOLS_FILE" "$ICON_ENTRIES_FILE" <<'PY'
from pathlib import Path
import re
import subprocess
import sys

iconfont_dir = Path(sys.argv[1])
map_file = Path(sys.argv[2])
header_file = Path(sys.argv[3])
symbols_file = Path(sys.argv[4])
entries_file = Path(sys.argv[5])

allowed_ext = {".ttf", ".otf", ".woff", ".woff2"}
font_files = sorted([p for p in iconfont_dir.iterdir() if p.is_file() and p.suffix.lower() in allowed_ext])

existing = {}
if map_file.exists():
    for line in map_file.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        value = value.strip()
        if key and value.lower().startswith("0x"):
            try:
                existing[key] = int(value, 16)
            except ValueError:
                pass

def next_free_codepoint(used, preferred_start=0xE900):
    for cp in range(preferred_start, 0xF8FF + 1):
        if cp not in used:
            return cp
    raise SystemExit("no free private-use codepoint available for icon fonts")

def normalize_name(stem: str) -> str:
    name = re.sub(r"[^a-zA-Z0-9]+", "_", stem.strip())
    name = re.sub(r"_+", "_", name).strip("_")
    if not name:
        name = "UNKNOWN"
    if name[0].isdigit():
        name = f"_{name}"
    name = name.upper()
    if not name.startswith("ICON_"):
        name = f"ICON_{name}"
    return name

def parse_code_from_stem(stem: str):
    # e.g. wifi_full_uE001.ttf or wifi_full_0xE001.ttf
    m = re.search(r"(?:_u|_0x)([0-9a-fA-F]{4,6})$", stem)
    if not m:
        return None
    return int(m.group(1), 16)

def parse_code_file(path: Path):
    # sidecar: wifi_full.code (content like E001 or 0xE001)
    code_file = path.with_suffix(".code")
    if not code_file.exists():
        return None
    text = code_file.read_text(encoding="utf-8").strip()
    if not text:
        return None
    text = text.upper()
    if text.startswith("0X"):
        text = text[2:]
    if not re.fullmatch(r"[0-9A-F]{4,6}", text):
        raise SystemExit(f"invalid code in {code_file.name}: {text}")
    return int(text, 16)

def parse_charset_tokens(charset_text: str):
    # format example: "0-1 20 e91b f001-f003"
    cps = []
    for token in charset_text.split():
        token = token.strip().lower()
        if not token:
            continue
        if "-" in token:
            a, b = token.split("-", 1)
            try:
                start = int(a, 16)
                end = int(b, 16)
            except ValueError:
                continue
            if end < start:
                start, end = end, start
            cps.extend(range(start, end + 1))
        else:
            try:
                cps.append(int(token, 16))
            except ValueError:
                continue
    return cps

def scan_font_codepoints(path: Path):
    # Use fontconfig tool to inspect glyph charset.
    try:
        out = subprocess.check_output(
            ["fc-scan", "--format", "%{charset}\\n", str(path)],
            text=True,
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        return []
    cps = parse_charset_tokens(out.strip())
    return sorted(set(cps))

def parse_code_from_font(path: Path):
    cps = scan_font_codepoints(path)
    if not cps:
        return None, []
    pua = [cp for cp in cps if 0xE000 <= cp <= 0xF8FF]
    return cps, pua

mapping = {}
file_to_entry = {}
errors = []
used_codes = set()
code_owner = {}
macro_candidates = {}

for f in font_files:
    macro = normalize_name(f.stem)

    cps, pua = parse_code_from_font(f)
    non_ascii = [cp for cp in cps if cp > 0x7F]
    candidates = []
    # Prefer PUA codepoints, then other non-ASCII codepoints.
    for cp in pua + non_ascii:
        if cp not in candidates:
            candidates.append(cp)
    macro_candidates[macro] = candidates

    source_code = None
    target_code = None
    explicit_target = False

    # 1) Detect source glyph from the icon font itself.
    if len(pua) == 1:
        source_code = pua[0]
    elif len(pua) == 0 and len(non_ascii) == 1:
        source_code = non_ascii[0]
    else:
        if len(pua) > 1:
            sample = " ".join(f"0x{cp:04X}" for cp in pua[:8])
            errors.append(
                f"ambiguous unicode for {f.name}; multiple PUA codepoints found ({sample}). "
                f"please keep a single glyph codepoint in the icon font"
            )
            continue
        errors.append(
            f"missing unicode for {f.name}; icon font must expose one non-ASCII glyph codepoint"
        )
        continue

    # 2) Stable target priority:
    # sidecar .code > filename suffix > existing generated map > auto-assign.
    explicit = parse_code_file(f)
    if explicit is None:
        explicit = parse_code_from_stem(f.stem)
    if explicit is not None:
        target_code = explicit
        explicit_target = True
    elif macro in existing:
        target_code = existing[macro]
    else:
        target_code = next_free_codepoint(used_codes)

    # 3) Target collisions are resolved by assigning a fresh output codepoint.
    if target_code in used_codes:
        owner = code_owner.get(target_code)
        replacement = next_free_codepoint(used_codes)
        level = "WARN" if explicit_target else "INFO"
        print(
            f"[buildFont] {level}: {macro} target 0x{target_code:04X} collides"
            f"{f' with {owner}' if owner else ''}; auto-remap output to 0x{replacement:04X}",
            file=sys.stderr,
        )
        target_code = replacement

    if source_code != target_code:
        print(
            f"[buildFont] INFO: {macro} remap {f.name} glyph "
            f"0x{source_code:04X} -> 0x{target_code:04X}",
            file=sys.stderr,
        )

    mapping[macro] = target_code
    file_to_entry[str(f.resolve())] = (source_code, target_code)
    used_codes.add(target_code)
    code_owner[target_code] = macro

if errors:
    for e in errors:
        print(f"[buildFont] ERROR: {e}", file=sys.stderr)
    raise SystemExit(1)

# stable output
map_lines = ["# Auto-generated by buildFont", "# ICON_NAME=0xCODEPOINT"]
for key in sorted(mapping.keys()):
    map_lines.append(f"{key}=0x{mapping[key]:04X}")
map_file.write_text("\n".join(map_lines) + "\n", encoding="utf-8")

header_lines = [
    "#pragma once",
    "",
    "/* Auto-generated by main/modules/ui/font/buildFont */",
]
for key in sorted(mapping.keys()):
    header_lines.append(f'#define {key} "\\u{mapping[key]:04X}"')
if not mapping:
    header_lines.append("/* no icon fonts found in main/modules/ui/font/iconfont */")
header_lines.append("")
header_file.parent.mkdir(parents=True, exist_ok=True)
header_file.write_text("\n".join(header_lines), encoding="utf-8")

symbols = "".join(chr(mapping[k]) for k in sorted(mapping.keys()))
symbols_file.write_text(symbols, encoding="utf-8")

entry_lines = []
for p in sorted(file_to_entry.keys()):
    source_code, target_code = file_to_entry[p]
    entry_lines.append(f"{p}\t0x{source_code:04X}\t0x{target_code:04X}")
entries_file.write_text("\n".join(entry_lines) + ("\n" if entry_lines else ""), encoding="utf-8")
PY

cat "$CHARS_FILE" "$ICON_SYMBOLS_FILE" | tr -d '\n' > "$ALL_SYMBOLS_FILE"
SYMBOLS=$(cat "$ALL_SYMBOLS_FILE")

cleanup_font() {
  local path="$1"
  python3 - <<PY
from pathlib import Path

p = Path("$path")
text = p.read_text(encoding="utf-8")
text = text.replace('#include "lvgl/lvgl.h"', '#include "lvgl.h"')
header_start = text.find("/*******************************************************************************")
if header_start != -1:
    header_end = text.find("******************************************************************************/", header_start)
    if header_end != -1:
        header_end += len("******************************************************************************/")
        text = text[header_end:].lstrip("\n")
p.write_text(text, encoding="utf-8")
PY
}

ICON_FONT_PATHS=()
ICON_FONT_SOURCE_CODES=()
ICON_FONT_TARGET_CODES=()
if [ -f "$ICON_ENTRIES_FILE" ]; then
  while IFS=$'\t' read -r p source_code target_code; do
    [ -z "${p:-}" ] && continue
    [ -z "${source_code:-}" ] && continue
    [ -z "${target_code:-}" ] && target_code="$source_code"
    ICON_FONT_PATHS+=("$p")
    ICON_FONT_SOURCE_CODES+=("$source_code")
    ICON_FONT_TARGET_CODES+=("$target_code")
  done < "$ICON_ENTRIES_FILE"
fi

for SIZE in "${TAGS[@]}"; do
  OUT="$OUT_DIR/font_${SIZE}.c"
  echo "building font size $SIZE -> $OUT"

  cmd=(lv_font_conv
    --size "$SIZE"
    --bpp 4
    --format lvgl
    --no-compress
    --output "$OUT"
  )

  cmd+=(--font "$FONT_SRC" --symbols "$SYMBOLS" --range 0x20-0x7F)

  for i in "${!ICON_FONT_PATHS[@]}"; do
    icon_font="${ICON_FONT_PATHS[$i]}"
    source_code="${ICON_FONT_SOURCE_CODES[$i]}"
    target_code="${ICON_FONT_TARGET_CODES[$i]}"
    if [ "$source_code" = "$target_code" ]; then
      cmd+=(--font "$icon_font" --range "${target_code}-${target_code}")
    else
      cmd+=(--font "$icon_font" --range "${source_code}=>${target_code}")
    fi
  done

  "${cmd[@]}"
  cleanup_font "$OUT"
done

echo "font build complete"
